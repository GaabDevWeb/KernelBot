# Copie para .env na raiz do projeto antes de: docker compose up -d
# Não commitar .env com secrets reais.

# --- LLM (em container, OpenRouter é o caminho mais simples) ---
ACL_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# Alternativa (requer runtime Cursor no host — raramente adequado em Docker):
# ACL_LLM_PROVIDER=cursor
# CURSOR_API_KEY=
# ACL_CURSOR_MODEL=composer-2.5

# --- MySQL (Aiven ou outro serviço gerido) ---
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- ACL ---
ACL_GLOBAL_CONTEXT=geral
ACL_GROUNDING_POLICY=anchored
ACL_CATALOG_ENABLED=false
ACL_RELOAD_BEARER_TOKEN=

# --- Porta publicada no host (docker-compose.yml) ---
KERNELBOT_PUBLISH_PORT=8001
