# Variáveis para colar no Railway Dashboard → Service → Variables
# (ou via CLI: railway variables set KEY=value)
# Não commitar secrets reais.

# --- Obrigatório: LLM (OpenRouter recomendado em PaaS) ---
ACL_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# --- Obrigatório: MySQL (Aiven ou plugin MySQL do Railway) ---
# Opção A — Aiven / MySQL externo (valores do teu .env local):
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Opção B — MySQL provisionado no Railway (referências entre serviços):
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_NAME=${{MySQL.MYSQLDATABASE}}
# DB_USER=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# --- ACL (produção) ---
ACL_GLOBAL_CONTEXT=geral
ACL_GROUNDING_POLICY=anchored
ACL_CATALOG_ENABLED=false
ACL_RELOAD_BEARER_TOKEN=

# --- Não definir PORT manualmente ---
# Railway injecta PORT automaticamente; a app escuta em 0.0.0.0:$PORT.
