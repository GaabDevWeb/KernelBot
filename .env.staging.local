# Staging local — MySQL em Docker (porta 3307). NÃO é produção/Aiven.
# Usado por: bin/staging-setup.sh, bin/staging-serve.sh

DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=kernelbot_staging
DB_USER=kb_staging
DB_PASSWORD=kb_staging_pw

ACL_GLOBAL_CONTEXT=geral
ACL_CATALOG_ENABLED=false

# OPENROUTER_API_KEY é herdada do teu .env principal em staging-serve.sh (chat real).
